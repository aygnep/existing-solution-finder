# Fixseek environment variables
#
# Mock mode is the default and does not need any token:
#   npm start -- solve "your problem"
#
# Real GitHub mode requires GITHUB_TOKEN:
#   npm start -- solve --real --provider github "your problem"
#
# Never commit .env or real API tokens.

# GitHub Personal Access Token for real GitHub mode.
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo or read-only public repository access.
GITHUB_TOKEN=

# Optional: web search provider configuration.
# Supported providers: brave, serpapi
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=

# Optional: log level (debug | info | warn | error)
LOG_LEVEL=warn

# Optional: max results requested per search provider
MAX_RESULTS_PER_PROVIDER=10

# Optional: request timeout in milliseconds
REQUEST_TIMEOUT_MS=10000
