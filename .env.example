# Environment Variables

# GitHub Personal Access Token (required for GitHub Search API)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo (read-only is fine)
GITHUB_TOKEN=your_github_token_here

# Optional: Web search provider API key
# Supported: brave, serpapi
WEB_SEARCH_PROVIDER=brave
WEB_SEARCH_API_KEY=your_web_search_key_here

# Optional: Log level (debug | info | warn | error)
LOG_LEVEL=info

# Optional: Max results per search provider
MAX_RESULTS_PER_PROVIDER=10

# Optional: Request timeout in milliseconds
REQUEST_TIMEOUT_MS=10000
