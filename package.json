{
  "name": "fixseek",
  "version": "0.1.0",
  "description": "Find existing fixes, tools, GitHub issues, packages, and workarounds before you build from scratch.",
  "main": "dist/cli/index.js",
  "bin": {
    "fixseek": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck && npm run build"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "github-search",
    "npm-search",
    "troubleshooting",
    "debugging",
    "bugfix",
    "workaround",
    "solution-finder"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aygnep/existing-solution-finder.git"
  },
  "bugs": {
    "url": "https://github.com/aygnep/existing-solution-finder/issues"
  },
  "homepage": "https://github.com/aygnep/existing-solution-finder#readme",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  }
}
